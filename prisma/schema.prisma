generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Module 1 (Auth) only for now — more models arrive with each later module.
model Matchmaker {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  phone        String?
  passwordHash String
  createdAt    DateTime        @default(now())
  profiles     Profile[]
  invites      ProfileInvite[]
}

model Profile {
  id           String        @id @default(cuid())
  matchmaker   Matchmaker    @relation(fields: [matchmakerId], references: [id])
  matchmakerId String

  status       ProfileStatus @default(PENDING_REVIEW)
  gender       Gender
  name         String
  age          Int
  education    String?
  profession   String?
  city         String?
  religion     String?
  sect         String?
  caste        String?
  familyDetails String?
  rawPastedText String?      // populated by Module 3 (AI extraction); unused for now

  // what this profile is looking for — used by the Module 6 matching engine
  prefAgeMin    Int?
  prefAgeMax    Int?
  prefEducation String?
  prefCity      String?
  prefReligion  String?
  prefSect      String?
  prefCaste     String?

  feeAgreed    Decimal? @default(0)
  amountPaid   Decimal? @default(0)

  photos    Photo[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentMatches     Match[] @relation("SourceProfile")
  receivedMatches Match[] @relation("TargetProfile")
}

model Match {
  id              String      @id @default(cuid())
  sourceProfile   Profile     @relation("SourceProfile", fields: [sourceProfileId], references: [id])
  sourceProfileId String
  targetProfile   Profile     @relation("TargetProfile", fields: [targetProfileId], references: [id])
  targetProfileId String
  score           Int
  status          MatchStatus @default(SUGGESTED)
  sharedAt        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // A given pair is tracked once — sharing the same candidate again updates
  // the existing row (score, sharedAt) instead of creating a duplicate.
  @@unique([sourceProfileId, targetProfileId])
}

model Photo {
  id         String   @id @default(cuid())
  profile    Profile  @relation(fields: [profileId], references: [id])
  profileId  String
  storageKey String   // key in object storage — never a public URL, never stored on the row directly
  createdAt  DateTime @default(now())
}

model ProfileInvite {
  id           String     @id @default(cuid())
  token        String     @unique
  matchmaker   Matchmaker @relation(fields: [matchmakerId], references: [id])
  matchmakerId String
  used         Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

enum ProfileStatus {
  PENDING_REVIEW
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum MatchStatus {
  SUGGESTED
  INTERESTED
  MEETING_SCHEDULED
  REJECTED
  MARRIED
}

